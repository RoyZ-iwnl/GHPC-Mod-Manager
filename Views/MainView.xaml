<UserControl x:Class="GHPC_Mod_Manager.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GHPC_Mod_Manager.Converters"
             xmlns:resources="clr-namespace:GHPC_Mod_Manager.Resources"
             mc:Ignorable="d"
             d:DesignHeight="920"
             d:DesignWidth="1440">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:InverseBooleanConverter x:Key="InvBool"/>
        <converters:StringToVisibilityConverter x:Key="StrToVis"/>

        <Style x:Key="RailTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource NavRailTextBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource DefaultFontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource TitleLarge}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RailCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource NavRailMutedTextBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource BodySmall}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="StatusPillTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
        </Style>

        <Style x:Key="StatusPillBorderStyle" TargetType="Border" BasedOn="{StaticResource BadgeBorderStyle}">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,8,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource CanvasBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource NavRailBrush}"
                BorderBrush="{DynamicResource NavRailBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid Margin="24,22,20,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Border Background="{DynamicResource AccentSoftBrush}"
                            CornerRadius="{DynamicResource RadiusSmall}"
                            Padding="10,6"
                            HorizontalAlignment="Left">
                        <TextBlock Text="Gunner HEAT PC!"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="{DynamicResource LabelLarge}"/>
                    </Border>

                    <TextBlock Margin="0,16,0,6"
                               Text="{x:Static resources:Strings.GHPCModManager}"
                               Style="{StaticResource RailTitleStyle}"/>
                </StackPanel>

                <ListBox Grid.Row="1"
                         Margin="0,28,0,20"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Style="{DynamicResource NavigationListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0"
                                         Width="8"
                                         Height="8"
                                         Margin="0,0,12,0"
                                         VerticalAlignment="Center"
                                         Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Label}"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                           FontSize="{DynamicResource BodyMedium}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        Background="#14000000"
                        BorderBrush="{DynamicResource NavRailBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusMedium}"
                        Padding="14">
                    <Button Content="{x:Static resources:Strings.Settings}"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{DynamicResource OutlinedButtonStyle}"
                            Background="#12000000"
                            Foreground="{DynamicResource NavRailTextBrush}"
                            BorderBrush="{DynamicResource NavRailBorderBrush}"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PageHeroCardStyle}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock Grid.Column="0" Margin="0,0,20,0"
                               Text="{Binding SelectedNavigationItem.Label}"
                               Style="{StaticResource PageTitleTextStyle}"/>




                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Margin="0,-4,-4,0">
                        <WrapPanel Margin="0,10,0,0">
                            <Border Style="{StaticResource StatusPillBorderStyle}"
                                    Background="{DynamicResource SuccessContainerBrush}"
                                    BorderBrush="{DynamicResource SuccessBrush}"
                                    Visibility="{Binding IsGameRunning, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{x:Static resources:Strings.Running}"
                                           Style="{StaticResource StatusPillTextStyle}"
                                           Foreground="{DynamicResource OnSuccessBrush}"/>  
                            </Border>

                            <Border Style="{StaticResource StatusPillBorderStyle}"
                                    Visibility="{Binding IsGameRunning, Converter={StaticResource InvBoolToVis}}">
                                <TextBlock Text="{x:Static resources:Strings.NotRunning}"
                                           Style="{StaticResource StatusPillTextStyle}"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                            </Border>

                            <Border Style="{StaticResource StatusPillBorderStyle}"
                                    Background="{DynamicResource WarningContainerBrush}"
                                    BorderBrush="{DynamicResource WarningBrush}"
                                    Visibility="{Binding IsOfflineMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{x:Static resources:Strings.OfflineModeTitle}"
                                    Style="{StaticResource StatusPillTextStyle}"
                                    Foreground="{DynamicResource OnWarningContainerBrush}"/>
                            </Border>

                            <Border Style="{StaticResource StatusPillBorderStyle}"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    Visibility="{Binding IsAppUpdateAvailable, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding LatestAppVersion}"
                                           Style="{StaticResource StatusPillTextStyle}"
                                           Foreground="{DynamicResource AccentStrongBrush}"/>
                            </Border>
                        </WrapPanel>
                        <Button Content="{x:Static resources:Strings.StartGame}"
                                Command="{Binding LaunchGameCommand}"
                                IsEnabled="{Binding IsGameRunning, Converter={StaticResource InvBool}}"
                                Margin="0,4,8,4"
                                Style="{DynamicResource FilledButtonStyle}"/>
                        <Button Content="{x:Static resources:Strings.OpenGameFolder}"
                                Command="{Binding OpenGameFolderCommand}"
                                Margin="0,4,0,4"
                                Style="{DynamicResource OutlinedButtonStyle}"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <Border Style="{StaticResource PageBannerCardStyle}"
                        Background="{DynamicResource ErrorContainerBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        Visibility="{Binding HasDelistedMods, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{x:Static resources:Strings.DelistedModBannerTitle}"
                                   Style="{StaticResource PageSectionTitleTextStyle}"
                                   Foreground="{DynamicResource OnErrorContainerBrush}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{x:Static resources:Strings.DelistedModBannerMessage}"
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Foreground="{DynamicResource OnErrorContainerBrush}"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource PageBannerCardStyle}"
                        Background="{DynamicResource WarningContainerBrush}"
                        BorderBrush="{DynamicResource WarningBrush}"
                        Visibility="{Binding HasUnknownFieldsMods, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{x:Static resources:Strings.UnknownConfigFieldsBannerTitle}"
                                   Style="{StaticResource PageSectionTitleTextStyle}"
                                   Foreground="{DynamicResource OnWarningContainerBrush}"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="{x:Static resources:Strings.UnknownConfigFieldsBannerMessage}"
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Foreground="{DynamicResource OnWarningContainerBrush}"/>
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource PageBannerCardStyle}"
                        Background="{DynamicResource AccentSoftBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        Visibility="{Binding IsAppUpdateAvailable, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock>
                                <Run Text="{x:Static resources:Strings.NewVersionAvailable}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding LatestAppVersion}"/>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{x:Static resources:Strings.ClickToDownloadAndInstall}"
                                       Style="{StaticResource PageSubtitleTextStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="{x:Static resources:Strings.CheckForUpdates}"
                                Command="{Binding DownloadAndInstallAppUpdateCommand}"
                                Margin="16,0,0,0"
                                Style="{DynamicResource FilledButtonStyle}"/>
                    </Grid>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource PageBannerCardStyle}"
                        Background="{DynamicResource SecondaryContainerBrush}"
                        BorderBrush="{DynamicResource SecondaryBrush}"
                        Visibility="{Binding IsTranslationUpdateAvailable, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Static resources:Strings.TranslationUpdateAvailable}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"
                                       Foreground="{DynamicResource OnSecondaryContainerBrush}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{x:Static resources:Strings.GoToTranslationManagement}"
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Foreground="{DynamicResource OnSecondaryContainerBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="{x:Static resources:Strings.GoToTranslation}"
                                Command="{Binding GoToTranslationManagementCommand}"
                                Margin="16,0,0,0"
                                Style="{DynamicResource FilledButtonStyle}"
                                Background="{DynamicResource SecondaryBrush}"
                                Foreground="{DynamicResource SurfaceBrush}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="0,12,0,12"
                    Style="{StaticResource PageSurfaceCardStyle}"
                    Padding="0">
                <ContentControl Margin="16"
                                Content="{Binding CurrentPageView}"/>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource PageToolbarCardStyle}"
                    Padding="6,2">
                <StatusBar Style="{DynamicResource MaterialStatusBarStyle}">
                    <StatusBarItem>
                        <TextBlock Text="{Binding FooterStatusMessage}"
                                   FontSize="{DynamicResource LabelLarge}"
                                   VerticalAlignment="Center"/>
                    </StatusBarItem>
                    <Separator/>
                    <StatusBarItem>
                        <TextBlock Text="{Binding SelectedNavigationItem.Label}"
                                   FontSize="{DynamicResource LabelLarge}"
                                   VerticalAlignment="Center"/>
                    </StatusBarItem>
                    <StatusBarItem HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FooterProgressText}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsFooterBusy, Converter={StaticResource BoolToVis}}"/>
                            <ProgressBar Width="150"
                                         Height="6"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding FooterProgressValue}"
                                         IsIndeterminate="{Binding IsFooterProgressIndeterminate}"
                                         Visibility="{Binding IsFooterBusy, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </StatusBarItem>
                </StatusBar>
            </Border>

            <Grid Grid.Row="1"
                  Grid.RowSpan="3"
                  Background="{DynamicResource ScrimBrush}"
                  Opacity="0.92"
                  Visibility="{Binding IsGameRunning, Converter={StaticResource BoolToVis}}">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource OutlineVariantBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="30"
                        Width="440"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{x:Static resources:Strings.GameRunning}"
                                   Style="{StaticResource PageTitleTextStyle}"
                                   TextAlignment="Center"/>
                        <TextBlock Margin="0,12,0,20"
                                   Text="{x:Static resources:Strings.GameRunningCannotOperate}"
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   TextAlignment="Center"/>
                        <Button Content="{x:Static resources:Strings.StopGame}"
                                Command="{Binding StopGameCommand}"
                                HorizontalAlignment="Center"
                                Style="{DynamicResource FilledButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  Grid.RowSpan="3"
                  Background="{DynamicResource ScrimBrush}"
                  Opacity="0.92"
                  Visibility="{Binding IsMelonLoaderNotInstalled, Converter={StaticResource BoolToVis}}">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource OutlineVariantBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource RadiusLarge}"
                        Padding="30"
                        Width="480"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{x:Static resources:Strings.MelonLoaderNotInstalledTitle}"
                                   Style="{StaticResource PageTitleTextStyle}"
                                   TextAlignment="Center"/>
                        <TextBlock Margin="0,12,0,20"
                                   Text="{x:Static resources:Strings.MelonLoaderNotInstalledMessage}"
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   TextAlignment="Center"/>
                        <Button Content="{x:Static resources:Strings.InstallMelonLoader}"
                                Command="{Binding GoToInstallMelonLoaderCommand}"
                                HorizontalAlignment="Center"
                                Style="{DynamicResource FilledButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.ColumnSpan="2"
              Background="{DynamicResource ScrimBrush}"
              Opacity="0.94"
              Visibility="{Binding IsMelonLoaderDisabled, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource OutlineVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource RadiusLarge}"
                    Padding="30"
                    Width="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{x:Static resources:Strings.MelonLoaderDisabledOverlayHint}"
                               Style="{StaticResource PageTitleTextStyle}"
                               TextAlignment="Center"/>
                    <TextBlock Margin="0,12,0,20"
                               Text="{Binding StatusMessage}"
                               Style="{StaticResource PageSubtitleTextStyle}"
                               TextAlignment="Center"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>
                    <Button Content="{x:Static resources:Strings.Settings}"
                            Command="{Binding OpenSettingsCommand}"
                            HorizontalAlignment="Center"
                            Style="{DynamicResource FilledButtonStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
