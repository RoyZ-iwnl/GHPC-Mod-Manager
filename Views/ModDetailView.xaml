<UserControl x:Class="GHPC_Mod_Manager.Views.ModDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GHPC_Mod_Manager.Converters"
             xmlns:resources="clr-namespace:GHPC_Mod_Manager.Resources"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StrToVis"/>
        <converters:StringToInverseVisibilityConverter x:Key="StrToInvVis"/>

        <Style x:Key="DetailItemCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource OutlineVariantBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusSmall}"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="MOD DETAIL"
                               Style="{StaticResource HeroEyebrowTextStyle}"/>
                    <TextBlock Margin="0,6,0,8"
                               Text="{Binding Mod.DisplayName}"
                               Style="{StaticResource PageTitleTextStyle}"/>
                    <TextBlock Text="{Binding Mod.Id}"
                               Style="{StaticResource MonoMetaValueTextStyle}"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"/>

                    <WrapPanel Margin="0,14,0,0">
                        <Border Style="{StaticResource BadgeBorderStyle}"
                                Background="{DynamicResource SuccessContainerBrush}"
                                BorderBrush="{DynamicResource SuccessBrush}"
                                Visibility="{Binding Mod.IsInstalled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{x:Static resources:Strings.Installed}"
                                       Style="{StaticResource BadgeTextStyle}"
                                       Foreground="{DynamicResource OnSuccessBrush}"/>
                        </Border>

                        <Border Style="{StaticResource BadgeBorderStyle}"
                                Visibility="{Binding Mod.IsManuallyInstalled, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{x:Static resources:Strings.Manual}"
                                       Style="{StaticResource BadgeTextStyle}"
                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                        </Border>

                        <Border Style="{StaticResource BadgeBorderStyle}"
                                Background="{DynamicResource ErrorContainerBrush}"
                                BorderBrush="{DynamicResource ErrorBrush}"
                                Visibility="{Binding Mod.IsUnsupportedManualMod, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{x:Static resources:Strings.UnsupportedManualMod}"
                                       Style="{StaticResource BadgeTextStyle}"
                                       Foreground="{DynamicResource OnErrorContainerBrush}"/>
                        </Border>

                        <Border Style="{StaticResource BadgeBorderStyle}"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                Visibility="{Binding Mod.CanUpdate, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{x:Static resources:Strings.Update}"
                                       Style="{StaticResource BadgeTextStyle}"
                                       Foreground="{DynamicResource AccentStrongBrush}"/>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="{x:Static resources:Strings.GoBack}"
                        Command="{Binding GoBackCommand}"
                        VerticalAlignment="Top"
                        Style="{DynamicResource OutlinedButtonStyle}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Style="{StaticResource AppScrollViewerStyle}"
                      Margin="0,18,0,0"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource PageSectionCardStyle}"
                            Visibility="{Binding Mod.IsUnsupportedManualMod, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.UnsupportedManualMod}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"
                                       Foreground="{DynamicResource ErrorBrush}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{x:Static resources:Strings.UnsupportedManualModDescription}"
                                       Style="{StaticResource PageSubtitleTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,16"
                            Style="{StaticResource PageSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.ModDescription}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding Mod.LocalizedDescription}"
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Visibility="{Binding Mod.LocalizedDescription, Converter={StaticResource StrToVis}}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding Mod.Id}"
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Visibility="{Binding Mod.LocalizedDescription, Converter={StaticResource StrToInvVis}}"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,16"
                            Style="{StaticResource PageSectionCardStyle}"
                            Visibility="{Binding Mod.LocalizedTags.Count, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.ModTags}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding Mod.LocalizedTags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource BadgeBorderStyle}">
                                            <TextBlock Text="{Binding}"
                                                       Style="{StaticResource BadgeTextStyle}"
                                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,16"
                            Style="{StaticResource PageSectionCardStyle}"
                            Visibility="{Binding Mod.SupportedGameVersions.Count, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.SupportedVersions}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding Mod.SupportedGameVersions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource BadgeBorderStyle}">
                                            <TextBlock Text="{Binding}"
                                                       Style="{StaticResource BadgeTextStyle}"
                                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource PageSidebarCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.Actions}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding Mod.IsUnsupportedManualMod, Converter={StaticResource BoolToVis}}">
                                <Button Content="{x:Static resources:Strings.Toggle}"
                                        Command="{Binding ToggleCommand}"
                                        Margin="0,0,0,10"
                                        Style="{DynamicResource OutlinedButtonStyle}"/>
                                <Button Content="{x:Static resources:Strings.Uninstall}"
                                        Command="{Binding UninstallManualModCommand}"
                                        Style="{DynamicResource FilledButtonStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding Mod.IsUnsupportedManualMod, Converter={StaticResource InvBoolToVis}}">
                                <TextBlock Text="{x:Static resources:Strings.InstalledVersion}"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           Visibility="{Binding Mod.IsInstalled, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding Mod.InstalledVersion}"
                                           Style="{StaticResource FieldValueTextStyle}"
                                           Visibility="{Binding Mod.IsInstalled, Converter={StaticResource BoolToVis}}"/>

                                <TextBlock Margin="0,14,0,6"
                                           Text="{x:Static resources:Strings.SelectVersion}"
                                           Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBlock Text="{x:Static resources:Strings.LoadingReleases}"
                                           Style="{StaticResource PageSubtitleTextStyle}"
                                           Visibility="{Binding IsLoadingReleases, Converter={StaticResource BoolToVis}}"/>
                                <ComboBox ItemsSource="{Binding AvailableReleases}"
                                          SelectedItem="{Binding SelectedRelease}"
                                          DisplayMemberPath="TagName"
                                          Visibility="{Binding IsLoadingReleases, Converter={StaticResource InvBoolToVis}}"/>

                                <WrapPanel Margin="0,18,0,0"
                                           Visibility="{Binding Mod.IsInstalled, Converter={StaticResource InvBoolToVis}}">
                                    <Button Content="{x:Static resources:Strings.QuickReinstall}"
                                            Command="{Binding InstallSelectedVersionCommand}"
                                            Margin="0,0,8,8"
                                            Style="{DynamicResource OutlinedButtonStyle}"
                                            Visibility="{Binding HasSelectedReleaseBackup, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="{Binding RedownloadReinstallText}"
                                            Command="{Binding RedownloadInstallSelectedVersionCommand}"
                                            Margin="0,0,0,8"
                                            Style="{DynamicResource FilledButtonStyle}"
                                            Visibility="{Binding HasSelectedReleaseBackup, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="{x:Static resources:Strings.InstallSpecificVersion}"
                                            Command="{Binding RedownloadInstallSelectedVersionCommand}"
                                            Margin="0,0,0,8"
                                            Style="{DynamicResource FilledButtonStyle}"
                                            Visibility="{Binding HasSelectedReleaseBackup, Converter={StaticResource InvBoolToVis}}"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,18,0,0"
                                           Visibility="{Binding Mod.IsInstalled, Converter={StaticResource BoolToVis}}">
                                    <Button Content="{x:Static resources:Strings.Update}"
                                            Command="{Binding UpdateCommand}"
                                            Margin="0,0,8,8"
                                            Style="{DynamicResource FilledButtonStyle}"
                                            Visibility="{Binding Mod.CanUpdate, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="{x:Static resources:Strings.InstallSpecificVersion}"
                                            Command="{Binding InstallSelectedVersionCommand}"
                                            Margin="0,0,8,8"
                                            Style="{DynamicResource OutlinedButtonStyle}"/>
                                    <Button Content="{x:Static resources:Strings.Toggle}"
                                            Command="{Binding ToggleCommand}"
                                            Margin="0,0,8,8"
                                            Style="{DynamicResource OutlinedButtonStyle}"/>
                                    <Button Content="{x:Static resources:Strings.Configure}"
                                            Command="{Binding ConfigureCommand}"
                                            Margin="0,0,8,8"
                                            Style="{DynamicResource OutlinedButtonStyle}"
                                            Visibility="{Binding Mod.HasConfiguration, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="{x:Static resources:Strings.Uninstall}"
                                            Command="{Binding UninstallCommand}"
                                            Margin="0,0,0,8"
                                            Style="{DynamicResource OutlinedButtonStyle}"/>
                                </WrapPanel>

                                <Button Content="{x:Static resources:Strings.ViewOnGitHub}"
                                        Command="{Binding OpenGitHubCommand}"
                                        Margin="0,12,0,0"
                                        HorizontalAlignment="Left"
                                        Style="{DynamicResource TextButtonStyle}"
                                        Visibility="{Binding Mod.GitHubRepositoryUrl, Converter={StaticResource StrToVis}}"/>
                            </StackPanel>

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding StatusMessage}"
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Style="{StaticResource PageSidebarCardStyle}"
                            Visibility="{Binding HasDependencies, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.DependenciesSection}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <ItemsControl Margin="0,14,0,0"
                                          ItemsSource="{Binding Dependencies}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DetailItemCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Left"
                                                        Style="{DynamicResource TextButtonStyle}"
                                                        Command="{Binding DataContext.NavigateToDependencyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding ModId}">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                </Button>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource BadgeBorderStyle}"
                                                        Background="{DynamicResource SuccessContainerBrush}"
                                                        BorderBrush="{DynamicResource SuccessBrush}"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{x:Static resources:Strings.Installed}"
                                                               Style="{StaticResource BadgeTextStyle}"
                                                               Foreground="{DynamicResource OnSuccessBrush}"/>
                                                </Border>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource BadgeBorderStyle}"
                                                        Background="{DynamicResource WarningContainerBrush}"
                                                        BorderBrush="{DynamicResource WarningBrush}"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource InvBoolToVis}}">
                                                    <TextBlock Text="{x:Static resources:Strings.NotInstalled}"
                                                               Style="{StaticResource BadgeTextStyle}"
                                                               Foreground="{DynamicResource OnWarningContainerBrush}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Style="{StaticResource PageSidebarCardStyle}"
                            Visibility="{Binding HasConflicts, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.ConflictsSection}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <ItemsControl Margin="0,14,0,0"
                                          ItemsSource="{Binding Conflicts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DetailItemCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Left"
                                                        Style="{DynamicResource TextButtonStyle}"
                                                        Command="{Binding DataContext.NavigateToDependencyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding ModId}">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                </Button>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource BadgeBorderStyle}"
                                                        Background="{DynamicResource WarningContainerBrush}"
                                                        BorderBrush="{DynamicResource WarningBrush}"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{x:Static resources:Strings.Installed}"
                                                               Style="{StaticResource BadgeTextStyle}"
                                                               Foreground="{DynamicResource OnWarningContainerBrush}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
