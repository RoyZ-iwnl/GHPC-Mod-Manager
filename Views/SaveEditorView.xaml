<UserControl x:Class="GHPC_Mod_Manager.Views.SaveEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:res="clr-namespace:GHPC_Mod_Manager.Resources"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1180">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 存档路径输入 -->
        <Border Grid.Row="0" Style="{StaticResource PageSectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{x:Static res:Strings.SaveEditor_FilePath}" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,8"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding SaveFilePath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource OutlinedTextBoxStyle}"
                             Margin="0,0,12,0"/>

                    <Button Grid.Column="1"
                            Content="{x:Static res:Strings.SaveEditor_Browse}"
                            Command="{Binding BrowseSaveFileCommand}"
                            Style="{DynamicResource OutlinedButtonStyle}"/>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,12,0,0"/>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="550"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 任务树状图 -->
            <Border Grid.Column="0" Style="{StaticResource PageSectionCardStyle}" Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{x:Static res:Strings.SaveEditor_TaskProgress}" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,12"/>

                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding TheaterTree}"
                              SelectedItemChanged="TreeView_SelectedItemChanged"
                              BorderThickness="0"
                              Background="Transparent">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Missions}">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Padding="4"/>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4">
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Width="200" TextTrimming="CharacterEllipsis"/>
                                            <ItemsControl ItemsSource="{Binding Factions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="4"
                                                                Padding="6,2"
                                                                Margin="4,0,0,0"
                                                                Background="{Binding IsCompleted, Converter={StaticResource BoolToCompletionBrushConverter}}"
                                                                BorderBrush="{Binding Name, Converter={StaticResource FactionForegroundConverter}}"
                                                                BorderThickness="1">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{Binding Name, Converter={StaticResource FactionForegroundConverter}}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="10"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Padding" Value="4"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <!-- 右侧面板 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 任务详情与操作 -->
                <Border Grid.Row="0" Style="{StaticResource PageSectionCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{x:Static res:Strings.SaveEditor_TaskOperation}" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,12"/>

                        <!-- 选中任务显示 -->
                        <StackPanel Visibility="{Binding SelectedMissionNode, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedMissionNode.Name}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{x:Static res:Strings.SaveEditor_ClickToToggleFaction}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding SelectedMissionNode.Factions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ToggleMissionStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Name}"
                                                Style="{DynamicResource OutlinedButtonStyle}"
                                                Margin="0,0,8,8"
                                                Padding="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{x:Static res:Strings.Toggle}" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{Binding Name, Converter={StaticResource FactionForegroundConverter}}"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock Text="{x:Static res:Strings.SaveEditor_SelectTaskFirst}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding SelectedMissionNode, Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- 备份管理 -->
                <Border Grid.Row="1" Style="{StaticResource PageSectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="{x:Static res:Strings.SaveEditor_BackupManagement}" Style="{StaticResource FieldLabelTextStyle}"/>
                            <Button Content="{x:Static res:Strings.SaveEditor_ManualBackup}"
                                    Command="{Binding ManualBackupCommand}"
                                    Style="{DynamicResource OutlinedButtonStyle}"
                                    HorizontalAlignment="Right"
                                    Padding="12,4"/>
                        </Grid>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Backups}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding FileName}" FontSize="11" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DisplayTime}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="{x:Static res:Strings.SaveEditor_Restore}"
                                                Command="{Binding DataContext.RestoreFromBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource OutlinedButtonStyle}"
                                                Padding="8,2"
                                                Margin="4,0"/>

                                        <Button Grid.Column="2"
                                                Content="{x:Static res:Strings.SaveEditor_Delete}"
                                                Command="{Binding DataContext.DeleteBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource OutlinedButtonStyle}"
                                                Padding="8,2"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Grid.Row="2"
                                   Text="{x:Static res:Strings.SaveEditor_AutoBackupHint}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,8,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部功能按钮 -->
        <Border Grid.Row="2" Style="{StaticResource PageSectionCardStyle}" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0">
                    <Button Content="{x:Static res:Strings.SaveEditor_OneKeyComplete}"
                            Command="{Binding CompleteAllMissionsCommand}"
                            Style="{DynamicResource FilledButtonStyle}"
                            Margin="0,0,12,0"
                            Padding="20,10"
                            IsEnabled="{Binding IsLoaded}"/>
                    <Button Content="{x:Static res:Strings.SaveEditor_OneKeyReset}"
                            Command="{Binding ResetProgressCommand}"
                            Style="{DynamicResource OutlinedButtonStyle}"
                            Margin="0,0,12,0"
                            Padding="20,10"
                            IsEnabled="{Binding IsLoaded}"/>
                    <Button Content="{x:Static res:Strings.SaveEditor_Save}"
                            Command="{Binding SaveFileCommand}"
                            Style="{DynamicResource FilledButtonStyle}"
                            Padding="20,10"
                            IsEnabled="{Binding HasChanges}"/>
                </WrapPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding HasChanges, Converter={StaticResource BoolToSaveHintConverter}}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>