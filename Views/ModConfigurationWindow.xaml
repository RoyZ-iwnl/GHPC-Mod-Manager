<Window x:Class="GHPC_Mod_Manager.Views.ModConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:GHPC_Mod_Manager.Converters"
        xmlns:resources="clr-namespace:GHPC_Mod_Manager.Resources"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1280"
        Height="760"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <converters:ConfigurationItemTypeConverter x:Key="ConfigurationItemTypeConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PageHeroCardStyle}">
            <StackPanel>
                <TextBlock Text="MOD CONFIGURATION"
                           Style="{StaticResource HeroEyebrowTextStyle}"/>
                <TextBlock Margin="0,6,0,8"
                           Text="{Binding ModDisplayName}"
                           Style="{StaticResource PageTitleTextStyle}"/>
                <TextBlock Text="{Binding ModId}"
                           Style="{StaticResource MonoMetaValueTextStyle}"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Style="{StaticResource AppScrollViewerStyle}"
                      Margin="0,16,0,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid HorizontalAlignment="Stretch">
                <StackPanel>
                    <Border Style="{StaticResource PageSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.ConfigurationPresets}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <TextBlock Margin="0,4,0,14"
                                       Text="{Binding FilteredConfigurationCount}"
                                       Style="{StaticResource PageSectionHintTextStyle}"/>

                            <WrapPanel Margin="0,0,0,14">
                                <ComboBox ItemsSource="{Binding Presets}"
                                          SelectedItem="{Binding SelectedPreset}"
                                          DisplayMemberPath="Name"
                                          Width="220"
                                          Margin="0,0,8,8"/>
                                <Button Content="{x:Static resources:Strings.LoadPreset}"
                                        Command="{Binding LoadPresetCommand}"
                                        Margin="0,0,8,8"
                                        Style="{DynamicResource OutlinedButtonStyle}"/>
                                <Button Content="{x:Static resources:Strings.SavePreset}"
                                        Command="{Binding SavePresetCommand}"
                                        Margin="0,0,8,8"
                                        Style="{DynamicResource OutlinedButtonStyle}"/>
                                <Button Content="{x:Static resources:Strings.DeletePreset}"
                                        Command="{Binding DeletePresetCommand}"
                                        Margin="0,0,16,8"
                                        Style="{DynamicResource OutlinedButtonStyle}"/>

                                <TextBox Text="{Binding NewPresetName}"
                                         Width="180"
                                         Margin="0,0,8,8"
                                         Style="{DynamicResource OutlinedTextBoxStyle}"/>
                                <Button Content="{x:Static resources:Strings.SaveAsPreset}"
                                        Command="{Binding SaveAsPresetCommand}"
                                        Margin="0,0,8,8"
                                        Style="{DynamicResource FilledButtonStyle}"/>
                                <Button Content="{x:Static resources:Strings.ResetConfiguration}"
                                        Command="{Binding ResetConfigurationCommand}"
                                        Margin="0,0,16,8"
                                        Style="{DynamicResource OutlinedButtonStyle}"
                                        Foreground="{DynamicResource ErrorBrush}"/>

                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Width="240"
                                         Margin="0,0,8,8"
                                         Style="{DynamicResource OutlinedTextBoxStyle}"/>
                            </WrapPanel>

                            <TextBlock Text="{x:Static resources:Strings.NoConfigurationOptions}"
                                       Margin="0,14,0,0"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource EmptyStateTextStyle}"
                                       Visibility="{Binding HasConfiguration, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <ItemsControl ItemsSource="{Binding FilteredConfiguration}"
                                          Visibility="{Binding HasConfiguration, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Border Margin="0,8,0,0"
                                                    Padding="15,10"
                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                    CornerRadius="{DynamicResource RadiusSmall}"
                                                    Visibility="{Binding IsStandaloneComment, Converter={StaticResource ConfigurationItemTypeConverter}, ConverterParameter=Standalone}">
                                                <TextBlock Text="{Binding Comment}"
                                                           FontStyle="Italic"
                                                           Style="{StaticResource PageSubtitleTextStyle}"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <Border Margin="0,8,0,0"
                                                    Padding="14"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource OutlineVariantBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{DynamicResource RadiusSmall}"
                                                    Visibility="{Binding IsStandaloneComment, Converter={StaticResource ConfigurationItemTypeConverter}, ConverterParameter=Configuration}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="320"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                Margin="0,0,14,0">
                                                        <TextBlock Text="{Binding Key}"
                                                                   FontWeight="SemiBold"
                                                                   Style="{StaticResource FieldValueTextStyle}"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Style="{StaticResource PageSectionHintTextStyle}"
                                                                   TextWrapping="Wrap"
                                                                   Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        <TextBox Text="{Binding Comment}"
                                                                 Margin="0,4,0,0"
                                                                 IsReadOnly="True"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 FontStyle="Italic"
                                                                 Foreground="{DynamicResource TertiaryBrush}"
                                                                 ToolTip="{x:Static resources:Strings.ClickToSelectAndCopyComment}"
                                                                 Visibility="{Binding HasComment, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1">
                                                        <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                                  Visibility="{Binding IsBooleanType, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                        <TextBox Text="{Binding StringValue, Mode=TwoWay}"
                                                                 Visibility="{Binding IsStringType, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                 Style="{DynamicResource OutlinedTextBoxStyle}"/>

                                                        <ComboBox ItemsSource="{Binding ChoiceOptions}"
                                                                  SelectedItem="{Binding StringValue, Mode=TwoWay}"
                                                                  Visibility="{Binding IsChoiceType, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                        <ItemsControl ItemsSource="{Binding MultipleChoiceOptions}"
                                                                      Visibility="{Binding IsMultipleChoiceType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Content="{Binding Name}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                              Margin="0,0,0,6"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2"
                Style="{StaticResource PageToolbarCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Style="{StaticResource PageSectionHintTextStyle}"/>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right">
                    <Button Content="{x:Static resources:Strings.Apply}"
                            Command="{Binding ApplyCommand}"
                            Margin="0,0,8,0"
                            Style="{DynamicResource FilledButtonStyle}"/>
                    <Button Content="{x:Static resources:Strings.OK}"
                            Command="{Binding OkCommand}"
                            Margin="0,0,8,0"
                            Style="{DynamicResource OutlinedButtonStyle}"/>
                    <Button Content="{x:Static resources:Strings.Cancel}"
                            Command="{Binding CancelCommand}"
                            Style="{DynamicResource OutlinedButtonStyle}"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
