<Window x:Class="GHPC_Mod_Manager.Views.AnnouncementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:resources="clr-namespace:GHPC_Mod_Manager.Resources"
        xmlns:controls="clr-namespace:GHPC_Mod_Manager.Views.Controls"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{x:Static resources:Strings.Announcement}"
        Width="760"
        Height="892"
        MinWidth="620"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None">

    <!-- WindowChrome保留系统边框和阴影效果 -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      NonClientFrameEdges="None"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 自定义标题栏 -->
        <controls:WindowTitleBar Grid.Row="0"/>

        <!-- 主内容 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PageHeroCardStyle}">
                <StackPanel>
                    <TextBlock Text="NOTICE"
                               Style="{StaticResource HeroEyebrowTextStyle}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="{x:Static resources:Strings.Announcement}"
                               Style="{StaticResource PageTitleTextStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,18,0,18"
                    Style="{StaticResource PageSurfaceCardStyle}"
                    Padding="10"
                    Background="{DynamicResource SurfaceBrush}">
                <Grid>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True"
                                     Width="220"
                                     Height="6"
                                     Margin="0,0,0,12"/>
                        <TextBlock Text="{x:Static resources:Strings.LoadingAnnouncement}"
                                   Style="{StaticResource PageSubtitleTextStyle}"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource EmptyStateTextStyle}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   MaxWidth="460"/>
                    </StackPanel>

                    <wv2:WebView2 x:Name="AnnouncementWebView"
                                  Margin="0"
                                  Visibility="{Binding HasContent, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  NavigationCompleted="AnnouncementWebView_NavigationCompleted"/>

                    <TextBlock Text="No announcement available"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Style="{StaticResource EmptyStateTextStyle}"
                               Visibility="{Binding HasContent, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PageToolbarCardStyle}">
                <DockPanel>
                    <CheckBox Content="{x:Static resources:Strings.DoNotShowAnnouncementBeforeUpdate}"
                              IsChecked="{Binding DoNotShowAgain}"
                              VerticalAlignment="Center"
                              DockPanel.Dock="Left"/>
                    <Button Content="{x:Static resources:Strings.Close}"
                            Width="120"
                            HorizontalAlignment="Right"
                            Style="{DynamicResource FilledButtonStyle}"
                            Click="CloseButton_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>