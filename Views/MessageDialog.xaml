<Window x:Class="GHPC_Mod_Manager.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GHPC_Mod_Manager.Models"
        Title=""
        Width="420"
        MinWidth="320"
        MaxWidth="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <!-- 对话框边框样式 -->
        <Style x:Key="DialogBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource OutlineVariantBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24"
                                      ShadowDepth="0"
                                      Opacity="0.25"
                                      Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 对话框按钮样式（主按钮） -->
        <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FilledButtonStyle}">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <!-- 对话框按钮样式（次按钮） -->
        <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlinedButtonStyle}">
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <!-- 对话框容器 -->
    <Border Style="{StaticResource DialogBorderStyle}"
            Margin="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题区域，支持拖拽移动窗口 -->
            <Border Grid.Row="0"
                    Padding="20,16,20,12"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    CornerRadius="16,16,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <!-- 图标 -->
                    <Grid x:Name="IconContainer"
                          Width="28"
                          Height="28"
                          Margin="0,0,12,0"
                          DockPanel.Dock="Left"
                          Visibility="Collapsed">
                        <!-- Information图标 -->
                        <Path x:Name="InformationIcon"
                              Data="{StaticResource IconInformation}"
                              Stroke="{DynamicResource AccentBrush}"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Visibility="Collapsed"/>

                        <!-- Warning图标 -->
                        <Path x:Name="WarningIcon"
                              Data="{StaticResource IconWarning}"
                              Stroke="{DynamicResource WarningBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Visibility="Collapsed"/>

                        <!-- Error图标-->
                        <Path x:Name="ErrorIcon"
                              Data="{StaticResource IconError}"
                              Stroke="{DynamicResource ErrorBrush}"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Visibility="Collapsed"/>

                        <!-- Success图标 -->
                        <Path x:Name="SuccessIcon"
                              Data="{StaticResource IconSuccess}"
                              Stroke="{DynamicResource SuccessBrush}"
                              StrokeThickness="2.5"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Visibility="Collapsed"/>

                        <!-- Question图标 -->
                        <Path x:Name="QuestionIcon"
                              Data="{StaticResource IconQuestion}"
                              Stroke="{DynamicResource AccentBrush}"
                              StrokeThickness="2"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Visibility="Collapsed"/>
                    </Grid>

                    <!-- 标题文字 -->
                    <TextBlock x:Name="TitleText"
                               Text=""
                               FontFamily="{DynamicResource DefaultFontFamily}"
                               FontSize="{DynamicResource TitleSmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <!-- 内容区域 -->
            <Border Grid.Row="1"
                    Padding="20,16"
                    Background="{DynamicResource SurfaceBrush}">
                <TextBlock x:Name="MessageText"
                           Text=""
                           FontFamily="{DynamicResource DefaultFontFamily}"
                           FontSize="{DynamicResource BodyMedium}"
                           FontWeight="Normal"
                           Foreground="{DynamicResource OnSurfaceBrush}"
                           TextWrapping="Wrap"
                           MaxHeight="280"/>
            </Border>

            <!-- 按钮区域 -->
            <Border Grid.Row="2"
                    Padding="20,12,20,16"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="0,0,16,16">
                <StackPanel x:Name="ButtonPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <!-- 确认按钮（OK） -->
                    <Button x:Name="OKButton"
                            Content="确认"
                            Style="{StaticResource DialogPrimaryButtonStyle}"
                            Click="OK_Click"
                            Visibility="Collapsed"/>
                    <!-- 取消按钮 -->
                    <Button x:Name="CancelButton"
                            Content="取消"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Click="Cancel_Click"
                            Visibility="Collapsed"/>
                    <!-- 是按钮 -->
                    <Button x:Name="YesButton"
                            Content="是"
                            Style="{StaticResource DialogPrimaryButtonStyle}"
                            Click="Yes_Click"
                            Visibility="Collapsed"/>
                    <!-- 否按钮 -->
                    <Button x:Name="NoButton"
                            Content="否"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Click="No_Click"
                            Visibility="Collapsed"/>
                    <!-- 打开目录按钮 -->
                    <Button x:Name="OpenFolderButton"
                            Content="打开目录"
                            Style="{StaticResource DialogPrimaryButtonStyle}"
                            Click="OpenFolder_Click"
                            Visibility="Collapsed"/>
                    <!-- 忽略按钮 -->
                    <Button x:Name="IgnoreButton"
                            Content="忽略"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Click="Ignore_Click"
                            Visibility="Collapsed"/>
                    <!-- 去设置更新按钮 -->
                    <Button x:Name="GoToSettingsButton"
                            Content="去设置更新"
                            Style="{StaticResource DialogPrimaryButtonStyle}"
                            Click="GoToSettings_Click"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>