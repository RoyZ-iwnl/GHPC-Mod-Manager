<UserControl x:Class="GHPC_Mod_Manager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GHPC_Mod_Manager.Converters"
             xmlns:resources="clr-namespace:GHPC_Mod_Manager.Resources"
             xmlns:helpers="clr-namespace:GHPC_Mod_Manager.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1180">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:InverseBooleanConverter x:Key="InvBool"/>
        <converters:UpdateChannelDisplayConverter x:Key="UpdateChannelDisplayConverter"/>

        <Style x:Key="SettingsRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>

    <Grid Width="1000">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PageHeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Margin="0,6,0,10"
                               Style="{StaticResource PageTitleTextStyle}">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource BracketTextConverter}">
                                <Binding Source="{x:Static resources:Strings.ProgramSettings}"/>
                                <Binding Source="{x:Static helpers:ThemeTracker.Instance}" Path="CurrentTheme"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top">
                    <Button Content="{x:Static resources:Strings.SaveSettings}"
                            Command="{Binding SaveSettingsCommand}"
                            Margin="0,0,8,0"
                            Style="{DynamicResource FilledButtonStyle}"/>
                    <Button Content="{x:Static resources:Strings.BackToMain}"
                            Command="{Binding BackToMainCommand}"
                            Style="{DynamicResource OutlinedButtonStyle}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Style="{StaticResource AppScrollViewerStyle}"
                      Margin="0,18,0,18"
                      VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Center"
                  MaxWidth="980">
            <StackPanel>
                <!-- 关于块 - 移到最上面 -->
                <Border Margin="0,0,0,16"
                        Style="{StaticResource PageSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageSectionTitleTextStyle}">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource BracketTextConverter}">
                                    <Binding Source="{x:Static resources:Strings.About}"/>
                                    <Binding Source="{x:Static helpers:ThemeTracker.Instance}" Path="CurrentTheme"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <Grid Margin="0,16,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static resources:Strings.ApplicationVersion}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Background="Transparent"
                                    HorizontalAlignment="Left"
                                    MouseLeftButtonDown="VersionText_MouseLeftButtonDown"
                                    Cursor="Arrow">
                                <TextBlock Text="{Binding ApplicationVersion}"
                                           Style="{StaticResource FieldValueTextStyle}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static resources:Strings.ProjectUrl}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    HorizontalAlignment="Left"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{DynamicResource TextButtonStyle}"
                                    Command="{Binding OpenProjectUrlCommand}">
                                <TextBlock Text="https://github.com/RoyZ-iwnl/GHPC-Mod-Manager/"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </Button>
                        </Grid>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="{x:Static resources:Strings.CheckForUpdates}"
                                    Command="{Binding CheckForAppUpdatesCommand}"
                                    Margin="0,0,12,8"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                            <Button Content="{x:Static resources:Strings.ShowAnnouncement}"
                                    Command="{Binding ShowAnnouncementCommand}"
                                    Margin="0,0,12,8"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                            <!-- TODO: 启用时取消注释 - 支持作者按钮 -->
                            <!--<Button Content="{x:Static resources:Strings.SupportAuthor}"
                                    Command="{Binding OpenSupportAuthorCommand}"
                                    Margin="0,0,12,8"
                                    Style="{DynamicResource FilledButtonStyle}"/>-->
                            <Button Content="{x:Static resources:Strings.FollowBilibili}"
                                    Command="{Binding OpenFollowBilibiliCommand}"
                                    Margin="0,0,12,8"
                                    Style="{DynamicResource FilledButtonStyle}"
                                    Visibility="{Binding IsChineseLanguage, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="{x:Static resources:Strings.JoinGhpcCommunity}"
                                    Command="{Binding OpenGhpcCommunityCommand}"
                                    Margin="0,0,0,8"
                                    Style="{DynamicResource FilledButtonStyle}"
                                    Visibility="{Binding IsChineseLanguage, Converter={StaticResource BoolToVis}}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Style="{StaticResource PageSectionCardStyle}">
                    <StackPanel>
                            <TextBlock Style="{StaticResource PageSectionTitleTextStyle}">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource BracketTextConverter}">
                                        <Binding Source="{x:Static resources:Strings.MainSettings}"/>
                                        <Binding Source="{x:Static helpers:ThemeTracker.Instance}" Path="CurrentTheme"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <Grid Style="{StaticResource SettingsRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                                <TextBlock Margin="0,16,0,0"
                                           Grid.Column="0"
                                           Text="{x:Static resources:Strings.ProgramLanguage}"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center"/>
                                <ComboBox Margin="0,16,0,0"
                                          Grid.Column="1"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedLanguage}"
                                          MaxWidth="260"
                                          HorizontalAlignment="Left">
                                    <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={x:Static converters:LanguageDisplayConverter.Instance}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <Grid Style="{StaticResource SettingsRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static resources:Strings.AppTheme}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <ComboBox ItemsSource="{Binding AvailableThemes}"
                                              SelectedItem="{Binding SelectedTheme}"
                                              MaxWidth="260"
                                              HorizontalAlignment="Left">   
                                    <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={x:Static converters:ThemeDisplayConverter.Instance}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="{x:Static resources:Strings.Apply}"
                                    Command="{Binding ChangeThemeCommand}"
                                    Margin="12,0,0,0"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                                </StackPanel>
                             
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static resources:Strings.UpdateChannel}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableUpdateChannels}"
                                      SelectedItem="{Binding SelectedUpdateChannel, Mode=TwoWay}"
                                      MaxWidth="320"
                                      HorizontalAlignment="Left">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource UpdateChannelDisplayConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <CheckBox Margin="0,16,0,8"
                                  IsChecked="{Binding SkipConflictCheck}">
                            <CheckBox.Content>
                                <TextBlock Text="{x:Static resources:Strings.SkipConflictCheckOnLaunch}"
                                           FontWeight="SemiBold"/>
                            </CheckBox.Content>
                        </CheckBox>

                        <CheckBox Margin="0,0,0,8"
                                  IsChecked="{Binding SkipIntegrityCheck}">
                            <CheckBox.Content>
                                <TextBlock Text="{x:Static resources:Strings.SkipIntegrityCheckOnLaunch}"
                                           FontWeight="SemiBold"/>
                            </CheckBox.Content>
                        </CheckBox>

                        <CheckBox Margin="0,0,0,8"
                                  IsChecked="{Binding OpenWebsiteOnStartup}">
                            <CheckBox.Content>
                                <TextBlock Text="{x:Static resources:Strings.OpenWebsiteOnStartup}"
                                           FontWeight="SemiBold"/>
                            </CheckBox.Content>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Style="{StaticResource PageSectionCardStyle}">
                    <StackPanel>
                            <TextBlock Style="{StaticResource PageSectionTitleTextStyle}">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource BracketTextConverter}">
                                        <Binding Source="{x:Static resources:Strings.GamePath}"/>
                                        <Binding Source="{x:Static helpers:ThemeTracker.Instance}" Path="CurrentTheme"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static resources:Strings.GameRootDirectory}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding GameRootPath}"
                                     IsReadOnly="True"
                                     Style="{DynamicResource OutlinedTextBoxStyle}"/>
                            <Button Grid.Column="2"
                                    Content="{x:Static resources:Strings.Browse}"
                                    Command="{Binding BrowseGameDirectoryCommand}"
                                    Margin="12,0,0,0"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Style="{StaticResource PageSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageSectionTitleTextStyle}">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource BracketTextConverter}">
                                    <Binding Source="{x:Static resources:Strings.DataSourceConfiguration}"/>
                                    <Binding Source="{x:Static helpers:ThemeTracker.Instance}" Path="CurrentTheme"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Margin="0,16,0,0"
                                   Text="{x:Static resources:Strings.GitHubApiToken}"
                                   Style="{StaticResource FieldLabelTextStyle}"/>
                        <TextBox Margin="0,0,0,8"
                                 Text="{Binding GitHubApiToken}"
                                 Style="{DynamicResource OutlinedTextBoxStyle}"/>
                        <TextBlock Margin="0,4,0,16"
                                   Text="{x:Static resources:Strings.GitHubApiTokenDescription}"
                                   Style="{StaticResource PageSectionHintTextStyle}"/>
                        <TextBlock Text="{x:Static resources:Strings.GitHubApiTokenHint}"
                                   Style="{StaticResource PageSectionHintTextStyle}"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource PageSectionHintTextStyle}">
                            <Hyperlink NavigateUri="https://github.com/settings/tokens"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="{x:Static resources:Strings.GitHubApiTokenGetUrl}"/>
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,6,0,16"
                                   Text="{x:Static resources:Strings.GitHubApiTokenPermissionHint}"
                                   Style="{StaticResource PageSectionHintTextStyle}"/>

                        <CheckBox Margin="0,0,0,8"
                                  IsChecked="{Binding UseGitHubProxy}"
                                  IsEnabled="{Binding IsGitHubProxyEnabled}"
                                  Visibility="{Binding IsGitHubProxyVisible, Converter={StaticResource BoolToVis}}">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="{x:Static resources:Strings.UseGitHubProxy}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,2,0,0"
                                               Text="{x:Static resources:Strings.GitHubProxyDescription}"
                                               Style="{StaticResource PageSectionHintTextStyle}"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>

                        <Grid Margin="24,0,0,16"
                              Visibility="{Binding UseGitHubProxy, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static resources:Strings.GitHubProxyServer}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableProxyServers}"
                                      SelectedItem="{Binding SelectedProxyServer}"
                                      MaxWidth="320"
                                      HorizontalAlignment="Left">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <CheckBox Margin="0,0,0,16"
                                  IsChecked="{Binding UseDnsOverHttps}"
                                  Visibility="{Binding IsDnsOverHttpsVisible, Converter={StaticResource BoolToVis}}">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="启用内置 DNS over HTTPS (DoH)"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,2,0,0"
                                               Text="按预设优先级依次尝试 DoH 节点，可改善 DNS 污染或解析失败问题。"
                                               Style="{StaticResource PageSectionHintTextStyle}"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>

                        <Grid Margin="0,0,0,16"
                              Visibility="{Binding IsDevMode, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static resources:Strings.MainConfigURL}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding MainConfigUrl}"
                                     Style="{DynamicResource OutlinedTextBoxStyle}"/>
                        </Grid>

                        <WrapPanel VerticalAlignment="Center">
                            <Button Content="{x:Static resources:Strings.ForceRefreshCloudConfigurations}"
                                    Command="{Binding ForceRefreshConfigurationsCommand}"
                                    Margin="0,0,12,0"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                            <TextBlock Text="{Binding RefreshStatus}"
                                       Style="{StaticResource FieldValueTextStyle}"
                                       VerticalAlignment="Center"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Style="{StaticResource PageSectionCardStyle}">
                    <StackPanel>

                            <TextBlock Style="{StaticResource PageSectionTitleTextStyle}">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource BracketTextConverter}">
                                        <Binding Source="{x:Static resources:Strings.MelonLoaderManagement}"/>
                                        <Binding Source="{x:Static helpers:ThemeTracker.Instance}" Path="CurrentTheme"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <WrapPanel Margin="0,16,0,14">
                                <TextBlock Margin="0,0,8,0"
                                           Text="{x:Static resources:Strings.MelonLoaderInstalledVersion}"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding MelonLoaderInstalledVersion}"
                                           Style="{StaticResource PageSectionHintTextStyle}"/>
                                <Border Style="{DynamicResource BadgeBorderStyle}"
                                    Background="{DynamicResource SuccessContainerBrush}"
                                    BorderBrush="{DynamicResource SuccessBrush}"
                                    Visibility="{Binding IsMelonLoaderInstalled, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Static resources:Strings.Installed}"
                                           Style="{StaticResource BadgeTextStyle}"
                                           Foreground="{DynamicResource OnSuccessBrush}"/>
                                </Border>

                                <Border Style="{DynamicResource BadgeBorderStyle}"
                                    Background="{DynamicResource WarningContainerBrush}"
                                    BorderBrush="{DynamicResource WarningBrush}"
                                    Visibility="{Binding IsMelonLoaderDisabled, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Static resources:Strings.Disabled}"
                                           Style="{StaticResource BadgeTextStyle}"
                                           Foreground="{DynamicResource OnWarningContainerBrush}"/>
                                </Border>
                                <Button Command="{Binding ToggleMelonLoaderCommand}"
                                        Margin="0,0,12,8"
                                        Style="{DynamicResource OutlinedButtonStyle}">
                                    <Button.Content>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{x:Static resources:Strings.DisableMelonLoader}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMelonLoaderDisabled}" Value="True">
                                                            <Setter Property="Text" Value="{x:Static resources:Strings.EnableMelonLoader}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                            </WrapPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- 标签 -->
                                    <ColumnDefinition Width="220"/>
                                    <!-- ComboBox 固定宽 -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- 安装/重装按钮 -->
                                </Grid.ColumnDefinitions>

                                <!-- 选择版本标签 -->
                                <TextBlock Grid.Column="0"
               Margin="0,0,8,0"
               Text="{x:Static resources:Strings.SelectVersion}"
               Style="{StaticResource FieldLabelTextStyle}"
               VerticalAlignment="Center"/>

                                <!-- 版本下拉框 -->
                                <ComboBox Grid.Column="1"
              ItemsSource="{Binding MelonLoaderReleases}"
              SelectedItem="{Binding SelectedMelonLoaderRelease}"
              DisplayMemberPath="TagName"
              HorizontalAlignment="Stretch"/>

                                <!-- 安装/重装按钮 -->
                                <Button Grid.Column="2"
            Command="{Binding ReinstallMelonLoaderCommand}"
            Margin="12,0,0,0"
            Style="{DynamicResource FilledButtonStyle}">
                                    <Button.Content>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{x:Static resources:Strings.ReinstallMelonLoader}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMelonLoaderInstalled}" Value="False">
                                                            <Setter Property="Text" Value="{x:Static resources:Strings.InstallMelonLoader}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.Content>
                                </Button>
                            </Grid>
                        </StackPanel>
                </Border>

                <Border Margin="0,0,0,16"
                        Style="{StaticResource PageSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageSectionTitleTextStyle}">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource BracketTextConverter}">
                                    <Binding Source="{x:Static resources:Strings.MaintenanceTools}"/>
                                    <Binding Source="{x:Static helpers:ThemeTracker.Instance}" Path="CurrentTheme"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <WrapPanel Margin="0,16,0,0">
                            <Button Content="{x:Static resources:Strings.ModInfoDumper}"
                                    Command="{Binding ShowModInfoDumperCommand}"
                                    Margin="0,0,12,8"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                            <Button Content="{x:Static resources:Strings.CleanTempFiles}"
                                    Command="{Binding CleanTempFilesCommand}"
                                    Margin="0,0,12,8"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                            <Button Content="{x:Static resources:Strings.CleanupDownloadedMods}"
                                    Command="{Binding CleanupModBackupsCommand}"
                                    Margin="0,0,12,8"
                                    Style="{DynamicResource OutlinedButtonStyle}"/>
                            <Button Content="{x:Static resources:Strings.ViewLogs}"
                                    Command="{Binding ShowLogWindowCommand}"
                                    Margin="0,0,0,8"
                                    Style="{DynamicResource TextButtonStyle}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
            </Grid>
        </ScrollViewer>

    </Grid>
</UserControl>
