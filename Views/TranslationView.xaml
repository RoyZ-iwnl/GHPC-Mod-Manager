<UserControl x:Class="GHPC_Mod_Manager.Views.TranslationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GHPC_Mod_Manager.Converters"
             xmlns:resources="clr-namespace:GHPC_Mod_Manager.Resources"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:BooleanAndToVisibilityConverter x:Key="BoolAndToVis"/>
        <converters:TranslationLanguageDisplayConverter x:Key="TransLangDisplay"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>        

        <ScrollViewer Grid.Row="1"
                      Style="{StaticResource AppScrollViewerStyle}"
                      Margin="0,14,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,0,18">
            <WrapPanel>
                <StackPanel Width="720"
                            Margin="0,0,18,18">
                    <Border Margin="0,0,0,16"
                            Style="{StaticResource PageSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.TranslationSystem}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <WrapPanel Margin="0,14,0,16">
                                <Border Style="{DynamicResource BadgeBorderStyle}"
                                        Background="{DynamicResource SuccessContainerBrush}"
                                        BorderBrush="{DynamicResource SuccessBrush}"
                                        Visibility="{Binding IsTranslationInstalled, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Static resources:Strings.Installed}"
                                               Style="{StaticResource BadgeTextStyle}"
                                               Foreground="{DynamicResource OnSuccessBrush}"/>
                                </Border>

                                <Border Style="{DynamicResource BadgeBorderStyle}"
                                        Background="{DynamicResource WarningContainerBrush}"
                                        BorderBrush="{DynamicResource WarningBrush}"
                                        Visibility="{Binding IsTranslationInstalled, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="{x:Static resources:Strings.NotInstalled}"
                                               Style="{StaticResource BadgeTextStyle}"
                                               Foreground="{DynamicResource OnWarningContainerBrush}"/>
                                </Border>

                                <Button Content="{x:Static resources:Strings.CheckForUpdates}"
                                            Command="{Binding CheckForTranslationUpdatesCommand}"
                                            Style="{DynamicResource OutlinedButtonStyle}"/>
                            </WrapPanel>

                            <WrapPanel>
                                <Button Content="{x:Static resources:Strings.InstallTranslationSystem}"
                                        Command="{Binding InstallTranslationCommand}"
                                        Margin="0,0,12,8"
                                        Style="{DynamicResource FilledButtonStyle}"
                                        Visibility="{Binding IsTranslationInstalled, Converter={StaticResource InvBoolToVis}}"/>

                                <Button Content="{x:Static resources:Strings.UpdateTranslationPlugin}"
                                        Command="{Binding UpdateTranslationPluginCommand}"
                                        Margin="0,0,12,8"
                                        Style="{DynamicResource FilledButtonStyle}">
                                    <Button.Visibility>
                                        <MultiBinding Converter="{StaticResource BoolAndToVis}">
                                            <Binding Path="IsTranslationInstalled"/>
                                            <Binding Path="IsTranslationPluginUpdateAvailable"/>
                                        </MultiBinding>
                                    </Button.Visibility>
                                </Button>

                                <Button Content="{x:Static resources:Strings.UpdateTranslationResources}"
                                        Command="{Binding UpdateTranslationCommand}"
                                        Margin="0,0,12,8"
                                        Style="{DynamicResource FilledButtonStyle}">
                                    <Button.Visibility>
                                        <MultiBinding Converter="{StaticResource BoolAndToVis}">
                                            <Binding Path="IsTranslationInstalled"/>
                                            <Binding Path="IsTranslationResourceUpdateAvailable"/>
                                        </MultiBinding>
                                    </Button.Visibility>
                                </Button>

                                <Button Content="{x:Static resources:Strings.UninstallTranslationSystem}"
                                        Command="{Binding UninstallTranslationCommand}"
                                        Margin="0,0,0,8"
                                        Style="{DynamicResource OutlinedButtonStyle}"
                                        Visibility="{Binding IsTranslationInstalled, Converter={StaticResource BoolToVis}}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,16"
                            Style="{StaticResource PageSectionCardStyle}"
                            Visibility="{Binding IsTranslationInstalled, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.LanguageSelection}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Static resources:Strings.CurrentLanguage}"
                                           Style="{StaticResource FieldLabelTextStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding CurrentTranslationLanguage}"
                                          MaxWidth="280"
                                          HorizontalAlignment="Left">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource TransLangDisplay}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="2"
                                        Content="{x:Static resources:Strings.Apply}"
                                        Command="{Binding SetTranslationLanguageCommand}"
                                        CommandParameter="{Binding CurrentTranslationLanguage}"
                                        Margin="12,0,0,0"
                                        Style="{DynamicResource FilledButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PageSectionCardStyle}"
                            Visibility="{Binding IsTranslationInstalled, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{x:Static resources:Strings.TranslationPluginControl}"
                                       Style="{StaticResource PageSectionTitleTextStyle}"/>
                            <WrapPanel Margin="0,14,0,16">
                                <Border Style="{DynamicResource BadgeBorderStyle}"
                                        Background="{DynamicResource SuccessContainerBrush}"
                                        BorderBrush="{DynamicResource SuccessBrush}"
                                        Visibility="{Binding IsTranslationPluginEnabled, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Static resources:Strings.Enabled}"
                                               Style="{StaticResource BadgeTextStyle}"
                                               Foreground="{DynamicResource OnSuccessBrush}"/>
                                </Border>

                                <Border Style="{DynamicResource BadgeBorderStyle}"
                                        Background="{DynamicResource WarningContainerBrush}"
                                        BorderBrush="{DynamicResource WarningBrush}"
                                        Visibility="{Binding IsTranslationPluginEnabled, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="{x:Static resources:Strings.Disabled}"
                                               Style="{StaticResource BadgeTextStyle}"
                                               Foreground="{DynamicResource OnWarningContainerBrush}"/>
                                </Border>
                            </WrapPanel>

                            <WrapPanel>
                                <Button Content="{x:Static resources:Strings.EnableTranslationPlugin}"
                                        Command="{Binding ToggleTranslationPluginCommand}"
                                        Margin="0,0,12,0"
                                        Style="{DynamicResource FilledButtonStyle}"
                                        Visibility="{Binding IsTranslationPluginEnabled, Converter={StaticResource InvBoolToVis}}"/>
                                <Button Content="{x:Static resources:Strings.DisableTranslationPlugin}"
                                        Command="{Binding ToggleTranslationPluginCommand}"
                                        Style="{DynamicResource OutlinedButtonStyle}"
                                        Visibility="{Binding IsTranslationPluginEnabled, Converter={StaticResource BoolToVis}}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Width="320"
                        Margin="0,0,0,18"
                        VerticalAlignment="Top"
                        Style="{StaticResource PageSidebarCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{x:Static resources:Strings.TranslationTipsTitle}"
                                   Style="{StaticResource PageSectionTitleTextStyle}"/>
                        <TextBlock Margin="0,12,0,0"
                                   Text="{x:Static resources:Strings.TranslationTipsContent}"
                                   Style="{StaticResource PageSubtitleTextStyle}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
