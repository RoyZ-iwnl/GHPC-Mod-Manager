<UserControl x:Class="GHPC_Mod_Manager.Views.ModBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GHPC_Mod_Manager.Converters"
             xmlns:resources="clr-namespace:GHPC_Mod_Manager.Resources"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StrToVis"/>
        <converters:GameVersionMatchBrushConverter x:Key="GameVersionMatchBrush"/>
        <converters:GameVersionMatchBoolConverter x:Key="GameVersionMatchBool"/>
        <converters:ResponsiveCardWidthConverter x:Key="ResponsiveCardWidthConverter"/>
        <converters:CollectionSummaryConverter x:Key="CollectionSummaryConverter"/>

        <Style x:Key="CompactFilledButtonStyle" TargetType="Button" BasedOn="{StaticResource FilledButtonStyle}">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontSize" Value="{DynamicResource LabelMedium}"/>
        </Style>

        <Style x:Key="CompactOutlinedButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlinedButtonStyle}">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontSize" Value="{DynamicResource LabelMedium}"/>
        </Style>

        <Style x:Key="DenseBrowserCardStyle" TargetType="Border" BasedOn="{StaticResource PageSectionCardStyle}">
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Height" Value="296"/>
        </Style>

        <Style x:Key="BrowserMetaLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="BrowserSummaryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldValueTextStyle}">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style x:Key="BrowserDescriptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PageSubtitleTextStyle}">
            <Setter Property="MaxHeight" Value="18"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Config.Requirements.Count}" Value="0"/>
                        <Condition Binding="{Binding Config.Conflicts.Count}" Value="0"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="TextWrapping" Value="Wrap"/>
                    <Setter Property="MaxHeight" Value="42"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BrowserBadgeBorderStyle" TargetType="Border" BasedOn="{StaticResource BadgeBorderStyle}">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,8,6"/>
        </Style>

        <Style x:Key="BrowserBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}">
            <Setter Property="FontSize" Value="{DynamicResource LabelMedium}"/>
        </Style>

        <Style x:Key="BrowserInfoBadgeBorderStyle" TargetType="Border" BasedOn="{StaticResource BadgeBorderStyle}">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
        </Style>

        <Style x:Key="BrowserInfoBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BadgeTextStyle}">
            <Setter Property="FontSize" Value="{DynamicResource LabelSmall}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PageToolbarCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{x:Static resources:Strings.Search}"
                                   Style="{StaticResource FieldLabelTextStyle}"/>
                        <TextBox Width="260"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource OutlinedTextBoxStyle}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FilteredModCount}"
                               Style="{StaticResource PageSectionHintTextStyle}"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,6"
                               Width="80"
                               TextAlignment="Center"
                               Visibility="{Binding FilteredMods.Count, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{x:Static resources:Strings.NoModsMatchFilter}"
                               Style="{StaticResource PageSectionHintTextStyle}"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,6"
                               Width="80"
                               TextAlignment="Center"
                               Visibility="{Binding FilteredMods.Count, Converter={StaticResource InvBoolToVis}}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{x:Static resources:Strings.FilterByTags}"
                               Style="{StaticResource FieldLabelTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding AvailableTags}"
                                  HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Style="{DynamicResource ChipToggleButtonStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <CheckBox Content="{x:Static resources:Strings.ShowUninstalledOnly}"
                              IsChecked="{Binding ShowUninstalledOnly}"
                              Margin="0,0,0,8"
                              HorizontalAlignment="Right"/>
                    <WrapPanel HorizontalAlignment="Right">
                        <Button Content="{x:Static resources:Strings.ClearTagFilter}"
                                Command="{Binding ClearTagFilterCommand}"
                                Margin="0,0,8,0"
                                Style="{DynamicResource OutlinedButtonStyle}"/>
                        <Button Content="{x:Static resources:Strings.Refresh}"
                                Command="{Binding RefreshCommand}"
                                Margin="0,0,8,0"
                                Style="{DynamicResource OutlinedButtonStyle}"/>
                        <Button Content="{x:Static resources:Strings.CheckForUpdates}"
                                Command="{Binding CheckForUpdatesCommand}"
                                Style="{DynamicResource FilledButtonStyle}"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Border Style="{StaticResource PageSectionCardStyle}"
                    Visibility="{Binding FilteredMods.Count, Converter={StaticResource InvBoolToVis}}">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="24">
                    <TextBlock Text="{x:Static resources:Strings.NoModsMatchFilter}"
                               Style="{StaticResource EmptyStateTextStyle}"/>
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="ResultsScrollViewer"
                          Style="{StaticResource AppScrollViewerStyle}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding FilteredMods.Count, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding FilteredMods}"
                              Width="{Binding ElementName=ResultsScrollViewer, Path=ActualWidth}"
                              Margin="0,0,-12,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,12,16"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource DenseBrowserCardStyle}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource ResponsiveCardWidthConverter}">
                                        <Binding ElementName="ResultsScrollViewer" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="124"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,16,0">
                                        <Button Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                HorizontalAlignment="Left"
                                                Style="{DynamicResource TextButtonStyle}"
                                                Command="{Binding DataContext.NavigateToDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="{DynamicResource TitleMedium}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                        </Button>
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Id}"
                                                   Style="{StaticResource MonoMetaValueTextStyle}"
                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                    </StackPanel>

                                    <Grid Grid.Row="0"
                                          Grid.RowSpan="3"
                                          Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    HorizontalAlignment="Right">
                                            <WrapPanel HorizontalAlignment="Right">
                                                <Border Style="{StaticResource BrowserBadgeBorderStyle}"
                                                        Background="{DynamicResource SuccessContainerBrush}"
                                                        BorderBrush="{DynamicResource SuccessBrush}"
                                                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{x:Static resources:Strings.Installed}"
                                                               Style="{StaticResource BrowserBadgeTextStyle}"
                                                               Foreground="{DynamicResource OnSuccessBrush}"/>
                                                </Border>

                                                <Border Style="{StaticResource BrowserBadgeBorderStyle}"
                                                        Background="{DynamicResource ErrorContainerBrush}"
                                                        BorderBrush="{DynamicResource ErrorBrush}"
                                                        Visibility="{Binding IsDelisted, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{x:Static resources:Strings.DelistedBadge}"
                                                               Style="{StaticResource BrowserBadgeTextStyle}"
                                                               Foreground="{DynamicResource OnErrorContainerBrush}"/>
                                                </Border>
                                            </WrapPanel>

                                            <ItemsControl Margin="0,8,0,0"
                                                          HorizontalAlignment="Right"
                                                          ItemsSource="{Binding SupportedGameVersions}"
                                                          Visibility="{Binding SupportedGameVersions.Count, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel HorizontalAlignment="Right"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource BrowserBadgeBorderStyle}">
                                                            <Border.Background>
                                                                <MultiBinding Converter="{StaticResource GameVersionMatchBrush}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.CurrentGameVersion"
                                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                </MultiBinding>
                                                            </Border.Background>
                                                            <TextBlock Text="{Binding}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource BrowserBadgeTextStyle}">
                                                                        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Value="match">
                                                                                <DataTrigger.Binding>
                                                                                    <MultiBinding Converter="{StaticResource GameVersionMatchBool}">
                                                                                        <Binding/>
                                                                                        <Binding Path="DataContext.CurrentGameVersion"
                                                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                                    </MultiBinding>
                                                                                </DataTrigger.Binding>
                                                                                <Setter Property="Foreground" Value="{DynamicResource OnSuccessBrush}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Value="mismatch">
                                                                                <DataTrigger.Binding>
                                                                                    <MultiBinding Converter="{StaticResource GameVersionMatchBool}">
                                                                                        <Binding/>
                                                                                        <Binding Path="DataContext.CurrentGameVersion"
                                                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                                                    </MultiBinding>
                                                                                </DataTrigger.Binding>
                                                                                <Setter Property="Foreground" Value="{DynamicResource OnWarningBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom">
                                            <Button Content="{x:Static resources:Strings.QuickReinstall}"
                                                    Command="{Binding DataContext.InstallModCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,0,8"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource CompactOutlinedButtonStyle}"
                                                    Visibility="{Binding CanQuickReinstall, Converter={StaticResource BoolToVis}}"/>

                                            <Button Content="{Binding DataContext.RedownloadReinstallText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Command="{Binding DataContext.RedownloadInstallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,0,8"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource CompactFilledButtonStyle}"
                                                    Visibility="{Binding CanQuickReinstall, Converter={StaticResource BoolToVis}}"/>

                                            <Button Content="{x:Static resources:Strings.InstallLatestVersion}"
                                                    Command="{Binding DataContext.InstallModCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,0,8"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource CompactFilledButtonStyle}"
                                                    Visibility="{Binding CanInstallFresh, Converter={StaticResource BoolToVis}}"/>

                                            <Button Content="{x:Static resources:Strings.Update}"
                                                    Command="{Binding DataContext.InstallModCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,0,8"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource CompactFilledButtonStyle}"
                                                    Visibility="{Binding CanUpdate, Converter={StaticResource BoolToVis}}"/>

                                            <Button Content="{x:Static resources:Strings.ViewDetails}"
                                                    Command="{Binding DataContext.NavigateToDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    HorizontalAlignment="Right"
                                                    Style="{StaticResource CompactOutlinedButtonStyle}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,10,16,0"
                                            Padding="0,1,0,0">
                                        <TextBlock Text="{Binding LocalizedDescription}"
                                                   Style="{StaticResource BrowserDescriptionTextStyle}"
                                                   Visibility="{Binding LocalizedDescription, Converter={StaticResource StrToVis}}"/>
                                    </Border>

                                     <Grid Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,12,16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Top">
                                            <TextBlock Text="{x:Static resources:Strings.DependenciesSection}"
                                                       Style="{StaticResource BrowserMetaLabelStyle}"
                                                       Visibility="{Binding Config.Requirements.Count, Converter={StaticResource BoolToVis}}"/>
                                            <ItemsControl ItemsSource="{Binding Config.Requirements}"
                                                          Visibility="{Binding Config.Requirements.Count, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource BrowserInfoBadgeBorderStyle}"
                                                                Background="{DynamicResource SecondaryContainerBrush}"
                                                                BorderBrush="{DynamicResource SecondaryBrush}">
                                                            <TextBlock Text="{Binding}"
                                                                       Style="{StaticResource BrowserInfoBadgeTextStyle}"
                                                                       Foreground="{DynamicResource OnSecondaryContainerBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="{x:Static resources:Strings.ConflictsSection}"
                                                       Style="{StaticResource BrowserMetaLabelStyle}"
                                                       Visibility="{Binding Config.Conflicts.Count, Converter={StaticResource BoolToVis}}"/>
                                            <ItemsControl ItemsSource="{Binding Config.Conflicts}"
                                                          Visibility="{Binding Config.Conflicts.Count, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource BrowserInfoBadgeBorderStyle}"
                                                                Background="{DynamicResource WarningContainerBrush}"
                                                                BorderBrush="{DynamicResource WarningBrush}">
                                                            <TextBlock Text="{Binding}"
                                                                       Style="{StaticResource BrowserInfoBadgeTextStyle}"
                                                                       Foreground="{DynamicResource OnWarningContainerBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Top">
                                            <TextBlock Text="{x:Static resources:Strings.ModTags}"
                                                       Style="{StaticResource BrowserMetaLabelStyle}"
                                                       Visibility="{Binding LocalizedTags.Count, Converter={StaticResource BoolToVis}}"/>
                                            <ItemsControl ItemsSource="{Binding LocalizedTags}"
                                                          Visibility="{Binding LocalizedTags.Count, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource BrowserInfoBadgeBorderStyle}">
                                                            <TextBlock Text="{Binding}"
                                                                       Style="{StaticResource BrowserInfoBadgeTextStyle}"
                                                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
