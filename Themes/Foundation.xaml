<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <FontFamily x:Key="DefaultFontFamily">Microsoft YaHei UI, Segoe UI, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="DisplayFontFamily">Microsoft YaHei UI, Segoe UI, Arial, sans-serif</FontFamily>
    <FontFamily x:Key="MonospaceFontFamily">Consolas, Courier New, monospace</FontFamily>

    <system:Double x:Key="DisplayLarge">48</system:Double>
    <system:Double x:Key="DisplayMedium">36</system:Double>
    <system:Double x:Key="DisplaySmall">28</system:Double>
    <system:Double x:Key="HeadlineLarge">30</system:Double>
    <system:Double x:Key="HeadlineMedium">24</system:Double>
    <system:Double x:Key="HeadlineSmall">20</system:Double>
    <system:Double x:Key="TitleLarge">22</system:Double>
    <system:Double x:Key="TitleMedium">18</system:Double>
    <system:Double x:Key="TitleSmall">15</system:Double>
    <system:Double x:Key="LabelLarge">14</system:Double>
    <system:Double x:Key="LabelMedium">12</system:Double>
    <system:Double x:Key="LabelSmall">11</system:Double>
    <system:Double x:Key="BodyLarge">16</system:Double>
    <system:Double x:Key="BodyMedium">14</system:Double>
    <system:Double x:Key="BodySmall">12</system:Double>

    <system:Double x:Key="Space1">4</system:Double>
    <system:Double x:Key="Space2">8</system:Double>
    <system:Double x:Key="Space3">12</system:Double>
    <system:Double x:Key="Space4">16</system:Double>
    <system:Double x:Key="Space5">20</system:Double>
    <system:Double x:Key="Space6">24</system:Double>
    <system:Double x:Key="Space7">32</system:Double>

    <CornerRadius x:Key="RadiusNone">0</CornerRadius>
    <CornerRadius x:Key="RadiusExtraSmall">6</CornerRadius>
    <CornerRadius x:Key="RadiusSmall">10</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">16</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">22</CornerRadius>
    <CornerRadius x:Key="RadiusExtraLarge">30</CornerRadius>
    <CornerRadius x:Key="BadgeCornerRadius">8</CornerRadius>

    <system:Double x:Key="Elevation0">0</system:Double>
    <system:Double x:Key="Elevation1">2</system:Double>
    <system:Double x:Key="Elevation2">6</system:Double>
    <system:Double x:Key="Elevation3">12</system:Double>

</ResourceDictionary>
