<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <CornerRadius x:Key="BadgeCornerRadius">8</CornerRadius>

    <Color x:Key="CanvasColor">#EFF3F8</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#F6F8FB</Color>
    <Color x:Key="SurfaceContainerColor">#E7EDF5</Color>
    <Color x:Key="OnSurfaceColor">#162131</Color>
    <Color x:Key="OnSurfaceMutedColor">#62748C</Color>
    <Color x:Key="BorderColor">#D4DDEA</Color>
    <Color x:Key="BorderStrongColor">#AEBCCE</Color>

    <Color x:Key="AccentColor">#3B76D1</Color>
    <Color x:Key="AccentStrongColor">#234C8A</Color>
    <Color x:Key="AccentSoftColor">#DCE9FF</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>

    <Color x:Key="NavRailColor">#0E1726</Color>
    <Color x:Key="NavRailBorderColor">#24324A</Color>
    <Color x:Key="NavRailTextColor">#F2F6FC</Color>
    <Color x:Key="NavRailMutedTextColor">#9FB0C9</Color>

    <Color x:Key="SuccessColor">#1E8A58</Color>
    <Color x:Key="SuccessSoftColor">#DDF7E9</Color>
    <Color x:Key="OnSuccessColor">#145338</Color>

    <Color x:Key="WarningColor">#C97A11</Color>
    <Color x:Key="WarningSoftColor">#FFF0D8</Color>
    <Color x:Key="OnWarningColor">#FFFFFF</Color>

    <Color x:Key="DangerColor">#C44940</Color>
    <Color x:Key="DangerSoftColor">#FFE4E1</Color>
    <Color x:Key="OnDangerColor">#FFFFFF</Color>

    <Color x:Key="SecondaryColor">#6A7892</Color>
    <Color x:Key="SecondarySoftColor">#E2E8F3</Color>
    <Color x:Key="TertiaryColor">#48657E</Color>

    <Color x:Key="ShadowColor">#220B1625</Color>
    <Color x:Key="ScrimColor">#AA0B1220</Color>

    <!-- 阵营颜色 -->
    <Color x:Key="FactionBlueColor">#2563EB</Color>
    <Color x:Key="FactionRedColor">#DC2626</Color>
    <Color x:Key="FactionNeutralColor">#B45309</Color>
    <Color x:Key="FactionBlueBgColor">#DBEAFE</Color>
    <Color x:Key="FactionRedBgColor">#FEE2E2</Color>
    <Color x:Key="FactionNeutralBgColor">#FEF3C7</Color>
    <Color x:Key="FactionIncompleteColor">#475569</Color>
    <Color x:Key="FactionIncompleteBgColor">#F8FAFC</Color>
    <Color x:Key="FactionIncompleteBorderColor">#CBD5E1</Color>
    <Color x:Key="FactionIncompleteTextDecorationColor">#64748B</Color>

    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SurfaceContainerBrush" Color="{StaticResource SurfaceContainerColor}"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{StaticResource OnSurfaceMutedColor}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource OnSurfaceMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentStrongBrush" Color="{StaticResource AccentStrongColor}"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}"/>
    <SolidColorBrush x:Key="OnAccentBrush" Color="{StaticResource OnAccentColor}"/>

    <SolidColorBrush x:Key="NavRailBrush" Color="{StaticResource NavRailColor}"/>
    <SolidColorBrush x:Key="NavRailBorderBrush" Color="{StaticResource NavRailBorderColor}"/>
    <SolidColorBrush x:Key="NavRailTextBrush" Color="{StaticResource NavRailTextColor}"/>
    <SolidColorBrush x:Key="NavRailMutedTextBrush" Color="{StaticResource NavRailMutedTextColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessContainerBrush" Color="{StaticResource SuccessSoftColor}"/>
    <SolidColorBrush x:Key="OnSuccessBrush" Color="{StaticResource OnSuccessColor}"/>

    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningContainerBrush" Color="{StaticResource WarningSoftColor}"/>
    <SolidColorBrush x:Key="OnWarningBrush" Color="{StaticResource OnWarningColor}"/>

    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="{StaticResource DangerSoftColor}"/>
    <SolidColorBrush x:Key="OnErrorBrush" Color="{StaticResource OnDangerColor}"/>
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="{StaticResource DangerColor}"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SecondaryContainerBrush" Color="{StaticResource SecondarySoftColor}"/>
    <SolidColorBrush x:Key="OnSecondaryBrush" Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="{StaticResource OnSurfaceColor}"/>

    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}"/>
    <SolidColorBrush x:Key="TertiaryContainerBrush" Color="{StaticResource SecondarySoftColor}"/>
    <SolidColorBrush x:Key="OnTertiaryBrush" Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="OnTertiaryContainerBrush" Color="{StaticResource OnSurfaceColor}"/>

    <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="OutlineVariantBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}"/>
    <SolidColorBrush x:Key="ScrimBrush" Color="{StaticResource ScrimColor}"/>

    <SolidColorBrush x:Key="FactionBlueBrush" Color="{StaticResource FactionBlueColor}"/>
    <SolidColorBrush x:Key="FactionRedBrush" Color="{StaticResource FactionRedColor}"/>
    <SolidColorBrush x:Key="FactionNeutralBrush" Color="{StaticResource FactionNeutralColor}"/>
    <SolidColorBrush x:Key="FactionBlueContainerBrush" Color="{StaticResource FactionBlueBgColor}"/>
    <SolidColorBrush x:Key="FactionRedContainerBrush" Color="{StaticResource FactionRedBgColor}"/>
    <SolidColorBrush x:Key="FactionNeutralContainerBrush" Color="{StaticResource FactionNeutralBgColor}"/>
    <SolidColorBrush x:Key="FactionIncompleteBrush" Color="{StaticResource FactionIncompleteColor}"/>
    <SolidColorBrush x:Key="FactionIncompleteContainerBrush" Color="{StaticResource FactionIncompleteBgColor}"/>
    <SolidColorBrush x:Key="FactionIncompleteBorderBrush" Color="{StaticResource FactionIncompleteBorderColor}"/>

    <LinearGradientBrush x:Key="HeroGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F6FBFF" Offset="0"/>
        <GradientStop Color="#E3EDFF" Offset="0.55"/>
        <GradientStop Color="#D8E7FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGlowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5B8FE2" Offset="0"/>
        <GradientStop Color="#315DAD" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource CanvasColor}"/>
    <SolidColorBrush x:Key="OnBackgroundBrush" Color="{StaticResource OnSurfaceColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{StaticResource OnAccentColor}"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource AccentSoftColor}"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="{StaticResource AccentStrongColor}"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SurfaceTintBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="InverseSurfaceBrush" Color="#142032"/>
    <SolidColorBrush x:Key="InverseOnSurfaceBrush" Color="#F4F7FC"/>
    <SolidColorBrush x:Key="InversePrimaryBrush" Color="#A9C6FF"/>
    <SolidColorBrush x:Key="OnWarningContainerBrush" Color="{StaticResource WarningColor}"/>

    <!-- Fallback textures for themes other than Endfield -->
    <SolidColorBrush x:Key="LightContourBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="DarkContourBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="IndustrialStripeBrush" Color="Transparent"/>

    <Style x:Key="SaveEditorTreeViewItemStyle" TargetType="TreeViewItem">
        <Setter Property="IsExpanded" Value="True"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ToggleButton x:Name="Expander"
                                      Grid.Row="0"
                                      Grid.Column="0"
                                      Width="20"
                                      Height="20"
                                      Margin="0,2,8,0"
                                      Focusable="False"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      Style="{StaticResource ComboBoxToggleButtonStyle}"
                                      Foreground="{DynamicResource OnSurfaceBrush}"/>

                        <Border x:Name="HeaderBorder"
                                Grid.Row="0"
                                Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ItemsPresenter x:Name="ItemsHost"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="16,4,0,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource OutlineVariantBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                            <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
